# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:latest

# Server Configuration
PORT=5000
NODE_ENV=development

# Browser Configuration
HEADLESS_MODE=false
BROWSER_WIDTH=1280
BROWSER_HEIGHT=720

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Retry Configuration
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_MS=1000
